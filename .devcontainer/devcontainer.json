{
  "name": "CostGate",
  "dockerComposeFile": "../docker-compose.dev.yml",
  "service": "dev",
  "workspaceFolder": "/app",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "postCreateCommand": "npm install && npm run build && npm run build:gate",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "golang.go",
        "redhat.vscode-yaml"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "remoteEnv": {
    "COSTGATE_PROBE_LOG_DIR": "/root/.costgate/logs",
    "COSTGATE_CLIENT": "cursor",
    "COSTGATE_HOST_ROOT": "/app"
  },
  "forwardPorts": []
}
