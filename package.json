{
  "name": "costgate",
  "private": true,
  "description": "Gate your MCP. Cut your bill.",
  "workspaces": [
    "packages/schema",
    "packages/probe"
  ],
  "scripts": {
    "help": "node scripts/npm-help.mjs",

    "build": "npm run build -w @costgate/schema && npm run build -w @costgate/probe",
    "build:gate": "cd packages/gate && CGO_ENABLED=0 go build -o bin/costgate-gate ./cmd/costgate-gate",
    "build:probe": "npm run build -w @costgate/probe",
    "build:schema": "npm run build -w @costgate/schema",
    "dev:probe": "npm run dev -w @costgate/probe",
    "install:gate": "bash scripts/install-gate.sh",

    "check:syntax": "node scripts/check-syntax.mjs",
    "compress-report": "node scripts/compress-report.mjs",
    "session-report": "node scripts/session-report.mjs",

    "cloud:upload": "node scripts/cloud-upload.mjs",

    "cursor:mcp": "node scripts/cursor-mcp.mjs",
    "cursor:measurement": "node scripts/cursor-mcp.mjs measurement",
    "cursor:production": "node scripts/cursor-mcp.mjs production",
    "cursor:registry": "node scripts/install-cursor-registry-hook.mjs",
    "cursor:update": "node scripts/cursor-update.mjs",

    "dashboard": "node scripts/dashboard-server.mjs",
    "dashboard:test": "node test/run-dashboard.mjs",

    "eval": "node test/eval/run.mjs",
    "eval:live": "node test/eval/run.mjs --live --tasks test/eval/tasks-live.json",
    "benchmark:ci": "node scripts/benchmark-ci.mjs",

    "feat:start": "node scripts/feat-workflow.mjs start",
    "feat:ship": "node scripts/feat-workflow.mjs ship",
    "feat:sync": "node scripts/feat-workflow.mjs sync",
    "hooks:install": "node scripts/install-git-hooks.mjs",

    "docker": "node scripts/docker-run.mjs",
    "docker:build": "node scripts/docker-run.mjs npm run build",
    "docker:gate": "node scripts/docker-run.mjs npm run build:gate",
    "docker:setup": "node scripts/docker-run.mjs npm install && node scripts/docker-run.mjs npm run build && node scripts/docker-run.mjs npm run build:gate",
    "docker:shell": "node scripts/docker-run.mjs bash",
    "docker:test": "docker compose -f docker-compose.test.yml --profile test run --rm test-runner",
    "docker:update": "node scripts/cursor-update.mjs --docker",

    "publish:check": "node scripts/publish-check.mjs",
    "release:check": "goreleaser check",

    "test": "npm run test:ci",
    "test:ci": "npm run check:syntax && npm run test:tokens && npm run test:schema && npm run test:integration && npm run eval && npm run benchmark:ci && npm run test:filesystem && npm run dashboard:test",
    "test:local": "npm run test:ci && npm run test:gate && npm run test:gate:filter && npm run test:cursor:gate",

    "test:gate-launch": "node test/costgate-gate-launch.test.mjs",
    "test:gate:compress": "cd packages/gate && go test ./internal/compress/...",
    "test:gate:codemode": "cd packages/gate && go test ./internal/codemode/...",
    "test:gate:filter": "node test/gate-filter.mjs",

    "test:integration": "node test/run.mjs",
    "test:schema": "node test/schema.test.mjs",
    "test:tokens": "node test/tokens.test.mjs",
    "test:filesystem": "node test/filesystem-mcp-smoke.mjs",

    "test:cursor:gate": "node test/cursor-gate-session.mjs",
    "test:cursor:registry": "node test/cursor-registry-hook.test.mjs",

    "test:dashboard": "node test/dashboard-api.test.mjs",
    "test:dashboard:all": "npm run dashboard:test",
    "test:dashboard:config-merge": "node test/dashboard-config-merge.test.mjs",
    "test:dashboard:control": "node test/dashboard-control.test.mjs",
    "test:dashboard:launcher": "node test/dashboard-launcher.test.mjs",
    "test:dashboard:marketplace": "node test/dashboard-marketplace.test.mjs",
    "test:dashboard:project-recommend": "node test/dashboard-project-recommend.test.mjs",
    "test:dashboard:routes": "node test/dashboard-routes.test.mjs",
    "test:dashboard:workspaces": "node test/dashboard-workspaces.test.mjs",

    "test:cursor-gate": "npm run test:cursor:gate",
    "test:cursor-registry-hook": "npm run test:cursor:registry",
    "registry:install-cursor-hook": "npm run cursor:registry"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/YukiMiyatake/costgate.git"
  }
}
