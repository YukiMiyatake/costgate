{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://costgate.dev/schema/log-event.json",
  "title": "CostGateLogEvent",
  "description": "One JSONL log line from Probe or Gate",
  "oneOf": [
    { "$ref": "#/$defs/sessionStart" },
    { "$ref": "#/$defs/sessionEnd" },
    { "$ref": "#/$defs/toolsList" },
    { "$ref": "#/$defs/toolCall" },
    { "$ref": "#/$defs/toolResult" },
    { "$ref": "#/$defs/gateEventToolsList" },
    { "$ref": "#/$defs/gateEventToolCall" }
  ],
  "$defs": {
    "base": {
      "type": "object",
      "required": ["type", "ts", "session_id"],
      "properties": {
        "type": { "type": "string" },
        "ts": { "type": "string", "format": "date-time" },
        "session_id": { "type": "string" }
      }
    },
    "sessionStart": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "session_start" },
            "client": { "type": "string" }
          },
          "required": ["client"]
        }
      ]
    },
    "sessionEnd": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "session_end" }
          }
        }
      ]
    },
    "toolsList": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "tools_list" },
            "tool_count": { "type": "integer", "minimum": 0 },
            "total_schema_bytes": { "type": "integer", "minimum": 0 },
            "estimated_tokens": { "type": "integer", "minimum": 0 },
            "tools": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["name", "schema_bytes"],
                "properties": {
                  "name": { "type": "string" },
                  "schema_bytes": { "type": "integer", "minimum": 0 },
                  "estimated_tokens": { "type": "integer", "minimum": 0 }
                }
              }
            }
          },
          "required": ["tool_count", "total_schema_bytes"]
        }
      ]
    },
    "toolCall": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "tool_call" },
            "client": { "type": "string" },
            "backend": { "type": "string" },
            "tool": { "type": "string" },
            "request_bytes": { "type": "integer", "minimum": 0 },
            "response_bytes": { "type": "integer", "minimum": 0 },
            "estimated_tokens": { "type": "integer", "minimum": 0 },
            "duration_ms": { "type": "integer", "minimum": 0 }
          },
          "required": ["client", "backend", "tool", "request_bytes"]
        }
      ]
    },
    "toolResult": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "tool_result" },
            "backend": { "type": "string" },
            "tool": { "type": "string" },
            "response_bytes": { "type": "integer", "minimum": 0 },
            "estimated_tokens": { "type": "integer", "minimum": 0 },
            "duration_ms": { "type": "integer", "minimum": 0 }
          },
          "required": ["backend", "tool", "response_bytes"]
        }
      ]
    },
    "gateEventBase": {
      "type": "object",
      "required": ["type", "event", "ts"],
      "properties": {
        "type": { "const": "gate_event" },
        "event": { "type": "string" },
        "ts": { "type": "string", "format": "date-time" },
        "generation_id": { "type": "string" },
        "conversation_id": { "type": "string" },
        "project_root": { "type": "string" }
      }
    },
    "gateEventToolsList": {
      "allOf": [
        { "$ref": "#/$defs/gateEventBase" },
        {
          "type": "object",
          "properties": {
            "event": { "const": "tools_list" },
            "backend": { "type": "string" },
            "tools_exposed": { "type": "integer", "minimum": 0 },
            "tokens_est": { "type": "integer", "minimum": 0 }
          },
          "required": ["backend", "tools_exposed", "tokens_est"]
        }
      ]
    },
    "gateEventToolCall": {
      "allOf": [
        { "$ref": "#/$defs/gateEventBase" },
        {
          "type": "object",
          "properties": {
            "event": { "const": "tool_call" },
            "tool": { "type": "string" },
            "response_bytes": { "type": "integer", "minimum": 0 },
            "compressed": { "type": "boolean" },
            "saved_bytes": { "type": "integer", "minimum": 0 }
          },
          "required": ["tool", "response_bytes", "compressed"]
        }
      ]
    }
  }
}
