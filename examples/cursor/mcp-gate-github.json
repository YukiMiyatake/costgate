{
  "mcpServers": {
    "serena": {
      "command": "/home/yuki/.local/bin/uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide"
      ]
    },
    "costgate-gate": {
