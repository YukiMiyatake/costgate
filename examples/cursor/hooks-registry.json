{
  "version": 1,
  "hooks": {
    "workspaceOpen": [
      {
        "command": "node /path/to/costgate/scripts/cursor-registry-hook.mjs",
        "timeout": 30
      }
    ],
    "postToolUse": [
      {
        "matcher": "Read",
        "command": "node /path/to/costgate/scripts/cursor-registry-hook.mjs",
        "timeout": 30
      }
    ],
    "beforeTabFileRead": [
      {
        "command": "node /path/to/costgate/scripts/cursor-registry-hook.mjs",
        "timeout": 30
      }
    ]
  }
}
