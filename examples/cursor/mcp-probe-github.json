{
  "mcpServers": {
    "serena": {
      "command": "/home/yuki/.local/bin/uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide"
      ]
    },
    "costgate-probe": {
      "command": "node",
      "args": ["/home/yuki/work/costgate/packages/probe/dist/index.js"],
      "env": {
        "COSTGATE_CONFIG": "/home/yuki/.costgate/backends.json",
        "COSTGATE_PROBE_LOG_DIR": "/home/yuki/.costgate/logs",
        "COSTGATE_CLIENT": "cursor"
      }
    }
  }
}
